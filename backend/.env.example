# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/ideasprit
# or Atlas: mongodb+srv://<user>:<pass>@cluster.mongodb.net/ideasprit

# JWT
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
JWT_EXPIRES_IN=7d

# Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=hello@ideasprit.com
EMAIL_TO=admin@ideasprit.com


# Frontend URL (CORS)
FRONTEND_URL=http://localhost:3000
