# ============================
# IdeaSprit – .gitignore
# ============================

# ---- Dependencies ----
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# ---- Next.js ----
frontend/.next/
frontend/out/
frontend/build/
frontend/.vercel

# ---- Production builds ----
backend/dist/
backend/build/

# ---- Environment variables ----
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
frontend/.env
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local
backend/.env
backend/.env.local

# ---- Logs ----
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log
logs/

# ---- Runtime data ----
pids
*.pid
*.seed
*.pid.lock

# ---- Testing ----
coverage/
.nyc_output
frontend/coverage/
backend/coverage/

# ---- Misc ----
.DS_Store
Thumbs.db
*.tsbuildinfo
.turbo/

# ---- Editor ----
.vscode/
.idea/
*.swp
*.swo
*~

# ---- OS ----
.DS_Store
ehthumbs.db
Desktop.ini

# ---- TypeScript ----
*.tsbuildinfo
next-env.d.ts
